      "contributes": {
        "featureFlags": {
          "conferenceCheckerEnabled": true,
          "checkEmbeddedFonts": true,
          "checkFigureReferences": true,
          "checkTableReferences": true,
          "errorDoctorEnabled": true,
          "explainErrors": true,
          "pdfComplianceEnabled": true,
          "checkPageCount": true,
          "checkType3Fonts": true
